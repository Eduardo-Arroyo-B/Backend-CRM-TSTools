// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  usuario      String    @unique
  password     String
  activo       Boolean
  ultimo_login DateTime?

  // Seguridad
  login_intentos  Int       @default(0)
  bloqueado_hasta DateTime?

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  // Relaciones
  Clientes Clients[]
  Marcas   Brands[]
  Modelos  Models[]
  Ordenes  Orders[]
}

model Clients {
  id              Int        @id @default(autoincrement())
  nombre          String
  telefono        String
  segundoTelefono String?
  direccion       String
  tipo            clientType
  fechaCreacion   DateTime   @default(now())
  creador         String     @db.Uuid

  // Relaciones
  Usuario User     @relation(fields: [creador], references: [id])
  Ordenes Orders[]
}

model Brands {
  id       Int      @id @default(autoincrement())
  marca    String
  usuario  String   @db.Uuid
  createAt DateTime @default(now())

  // Relaciones
  Usuario   User       @relation(fields: [usuario], references: [id])
  Modelos   Models[]
  Ordenes   Orders[]
  Servicios Services[]
}

model Models {
  id        Int    @id @default(autoincrement())
  nombre    String
  usuarioId String @db.Uuid
  brandId   Int

  // Relaciones
  Marca     Brands     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  Usuario   User       @relation(fields: [usuarioId], references: [id])
  Ordenes   Orders[]
  Servicios Services[]
}

model Orders {
  id          Int        @id @default(autoincrement())
  clienteId   Int
  marcaId     Int
  modeloId    Int
  servicioId  Int
  atendio     String     @db.Uuid
  estado      estado
  total       Int
  estado_pago estadoPago
  descripcion String?
  createAt    DateTime   @default(now())

  // Relaciones
  Clientes Clients  @relation(fields: [clienteId], references: [id])
  Usuario  User     @relation(fields: [atendio], references: [id])
  Marca    Brands   @relation(fields: [marcaId], references: [id])
  Modelo   Models   @relation(fields: [modeloId], references: [id])
  Servicio Services @relation(fields: [servicioId], references: [id])
}

model Services {
  id               Int      @id @default(autoincrement())
  tipo             String
  equipo           String
  concepto         String
  marcaId          Int
  modeloId         Int
  garantia         String
  precio_publico   String
  precio_mayorista String
  createAt         DateTime @default(now())

  // Relaciones
  Marca   Brands   @relation(fields: [marcaId], references: [id])
  Modelo  Models   @relation(fields: [modeloId], references: [id])
  Ordenes Orders[]
}

enum estado {
  PENDIENTE
  ENPROCESO
  REPARADO
}

enum estadoPago {
  PENDIENTE
  DEBE
  PAGADO
  SINCOSTO
}

enum clientType {
  PUBLICO
  LOCATARIO
  MAYORISTA
  EMPRESA
}
