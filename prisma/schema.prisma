// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid()) @db.Uuid
  usuario  String  @unique
  password String?
  email    String  @unique
  activo   Boolean

  googleId String? @unique

  // Seguridad
  ultimo_login    DateTime?
  login_intentos  Int       @default(0)
  bloqueado_hasta DateTime?

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  // Relaciones
  Clientes Clients[]
  Marcas   Brands[]
  Modelos  Models[]
  Ordenes  Orders[]
  tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  tenantId String?   @db.Uuid
}

model Clients {
  id              Int        @id @default(autoincrement())
  nombre          String
  telefono        String
  segundoTelefono String?
  direccion       String
  tipo            clientType
  fechaCreacion   DateTime   @default(now())
  creador         String     @db.Uuid

  // Relaciones
  Usuario  User     @relation(fields: [creador], references: [id])
  Ordenes  Orders[]
  tenant   Tenant?  @relation(fields: [tenantId], references: [id])
  tenantId String?  @db.Uuid
}

model Brands {
  id       Int      @id @default(autoincrement())
  marca    String
  usuario  String   @db.Uuid
  createAt DateTime @default(now())

  // Relaciones
  Usuario   User       @relation(fields: [usuario], references: [id])
  Modelos   Models[]
  Ordenes   Orders[]
  Servicios Services[]
  tenant    Tenant?    @relation(fields: [tenantId], references: [id])
  tenantId  String?    @db.Uuid
}

model Models {
  id        Int    @id @default(autoincrement())
  nombre    String
  usuarioId String @db.Uuid
  brandId   Int

  // Relaciones
  Marca     Brands     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  Usuario   User       @relation(fields: [usuarioId], references: [id])
  Ordenes   Orders[]
  Servicios Services[]
  tenant    Tenant?    @relation(fields: [tenantId], references: [id])
  tenantId  String?    @db.Uuid
}

model Orders {
  id Int @id @default(autoincrement())

  clienteId  Int
  marcaId    Int
  modeloId   Int
  servicioId Int

  atendio String @db.Uuid

  estado      estado
  estado_pago estadoPago

  total       Int
  descripcion String?

  // DATOS EQUIPO
  imei       String?
  enciende   Boolean @default(true)
  bateria    Boolean @default(true)
  bandejaSim Boolean @default(true)
  golpes     Boolean @default(false)
  mojado     Boolean @default(false)

  // EXTRA
  contrasena    String?
  observaciones String?

  // COMERCIAL
  garantia Int?
  pago     Int?

  // Validacion para seguimiento
  trackingToken String   @unique
  createAt      DateTime @default(now())

  // Relaciones
  Clientes Clients  @relation(fields: [clienteId], references: [id])
  Usuario  User     @relation(fields: [atendio], references: [id])
  Marca    Brands   @relation(fields: [marcaId], references: [id])
  Modelo   Models   @relation(fields: [modeloId], references: [id])
  Servicio Services @relation(fields: [servicioId], references: [id])
  tenant   Tenant?  @relation(fields: [tenantId], references: [id])
  tenantId String?  @db.Uuid
}

model Services {
  id               Int      @id @default(autoincrement())
  tipo_servicio    Int
  equipoId         Int
  conceptoId       Int
  marcaId          Int
  modeloId         Int
  garantia         String
  precio_publico   String
  precio_mayorista String
  notas            String?
  proceso          String?
  fotoURL          String?
  createAt         DateTime @default(now())

  // Relaciones
  Marca        Brands       @relation(fields: [marcaId], references: [id])
  Modelo       Models       @relation(fields: [modeloId], references: [id])
  Equipo       Devices      @relation(fields: [equipoId], references: [id])
  Concepto     Concept      @relation(fields: [conceptoId], references: [id])
  TipoServicio ServiceTypes @relation(fields: [tipo_servicio], references: [id])
  Ordenes      Orders[]
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  tenantId     String?      @db.Uuid
}

model Devices {
  id     Int    @id @default(autoincrement())
  nombre String

  // Relaciones
  Servicios Services[]
}

model ServiceTypes {
  id          Int     @id @default(autoincrement())
  nombre      String
  descripcion String
  activo      Boolean

  // Relaciones
  Servicios Services[]
}

model Concept {
  id     Int    @id @default(autoincrement())
  nombre String

  // Relaciones
  Servicios Services[]
}

model Tenant {
  id     String @id @default(uuid()) @db.Uuid
  nombre String

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  usuarios  User[]
  clientes  Clients[]
  marcas    Brands[]
  modelos   Models[]
  ordenes   Orders[]
  servicios Services[]
}

enum estado {
  PENDIENTE
  ENPROCESO
  REPARADO
}

enum estadoPago {
  PENDIENTE
  DEBE
  PAGADO
  SINCOSTO
}

enum clientType {
  PUBLICO
  LOCATARIO
  MAYORISTA
  EMPRESA
}
